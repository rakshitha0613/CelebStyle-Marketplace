{
  "title": "CelebStyle — Application Overview",
  "uid":   "celebstyle-overview",
  "time":  { "from": "now-1h", "to": "now" },
  "refresh": "30s",
  "panels": [
    {
      "id": 1, "type": "stat", "title": "Request Rate (req/s)",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "expr": "sum(rate(http_requests_total[5m]))",
        "legendFormat": "req/s"
      }]
    },
    {
      "id": 2, "type": "stat", "title": "Error Rate (%)",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "expr": "100 * sum(rate(http_requests_total{status_code=~'5..'}[5m])) / sum(rate(http_requests_total[5m]))",
        "legendFormat": "error %"
      }]
    },
    {
      "id": 3, "type": "stat", "title": "p99 Latency (ms)",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket[5m])) by (le)) * 1000",
        "legendFormat": "p99 ms"
      }]
    },
    {
      "id": 4, "type": "stat", "title": "Orders Created (total)",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "expr": "celebstyle_orders_created_total",
        "legendFormat": "orders"
      }]
    },
    {
      "id": 5, "type": "timeseries", "title": "HTTP Request Rate by Route",
      "gridPos": { "x": 0, "y": 4, "w": 24, "h": 8 },
      "targets": [{
        "expr": "sum by (route) (rate(http_requests_total[5m]))",
        "legendFormat": "{{route}}"
      }]
    },
    {
      "id": 6, "type": "timeseries", "title": "Latency Percentiles",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket[5m])) by (le)) * 1000", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le)) * 1000", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket[5m])) by (le)) * 1000", "legendFormat": "p99" }
      ]
    },
    {
      "id": 7, "type": "timeseries", "title": "Node.js Heap Usage",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [{
        "expr": "nodejs_heap_size_used_bytes{service='celebstyle-backend'} / 1024 / 1024",
        "legendFormat": "heap MB"
      }]
    }
  ],
  "schemaVersion": 38,
  "version": 1
}

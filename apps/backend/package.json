    "test:ar-camera": "tsx src/__tests__/ar.camera.test.ts",
    "test:ar-segmentation": "tsx src/__tests__/ar.segmentation.test.ts",
    "test:ar-overlay": "tsx src/__tests__/ar.overlay.test.ts",
    "test:ar-3d": "tsx src/__tests__/ar.3d.test.ts",
    "test:ar-fit": "tsx src/__tests__/ar.fit.test.ts",

# Copy this file to .env and fill in your values.

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=4000

# ── Database — runtime (required) ─────────────────────────────────────────────
# Pooled connection used by the Express application and Prisma Client at runtime.
# For Supabase: use the connection pooler URL (port 6543, ?pgbouncer=true).
# For a plain PostgreSQL server (no pooler): use the standard URL (port 5432).
DATABASE_URL="postgresql://<user>:<password>@<host>:6543/postgres?pgbouncer=true"

# ── Database — migrations only (optional at runtime) ──────────────────────────
# Direct (non-pooled) connection used exclusively by Prisma CLI commands:
#   prisma migrate deploy / dev / reset
#   prisma db push
#   npm run seed
# Required when DATABASE_URL points to a pgBouncer pooler, because pgBouncer
# transaction mode does not support the DDL statements Prisma migrate uses.
# For Supabase: use the direct connection URL (port 5432, no pgbouncer param).
# If you are not using pgBouncer you may omit this; it defaults to DATABASE_URL.
DIRECT_URL="postgresql://<user>:<password>@<host>:5432/postgres"

# ── Authentication (auth sprint) ───────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="<replace-with-a-long-random-secret>"

# ── AI/Embeddings (optional) ───────────────────────────────────────────────────
# If set, uses OpenAI text-embedding-3-small for product embeddings.
# If not set, falls back to deterministic bag-of-words embeddings (always available).
# OPENAI_API_KEY="sk-..."

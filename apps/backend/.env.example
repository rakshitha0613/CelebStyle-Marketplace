# Copy this file to .env and fill in your values.

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── Database — runtime (required) ─────────────────────────────────────────────
# Pooled connection used by the Express application and Prisma Client at runtime.
# For Supabase: use the connection pooler URL (port 6543, ?pgbouncer=true).
# For a plain PostgreSQL server (no pooler): use the standard URL (port 5432).
DATABASE_URL="postgresql://<user>:<password>@<host>:6543/postgres?pgbouncer=true"

# ── Database — migrations only (optional at runtime) ──────────────────────────
# Direct (non-pooled) connection used exclusively by Prisma CLI commands:
#   prisma migrate deploy / dev / reset
#   prisma db push
#   npm run seed
# Required when DATABASE_URL points to a pgBouncer pooler, because pgBouncer
# transaction mode does not support the DDL statements Prisma migrate uses.
# For Supabase: use the direct connection URL (port 5432, no pgbouncer param).
# If you are not using pgBouncer you may omit this; it defaults to DATABASE_URL.
DIRECT_URL="postgresql://<user>:<password>@<host>:5432/postgres"

# ── Authentication (auth sprint) ───────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="<replace-with-a-long-random-secret>"

# ── Payment Gateway (optional) ────────────────────────────────────────────────
# Defaults to "simulated" — no credentials required for development.
# Set to "razorpay" in production and fill in the keys below.
PAYMENT_PROVIDER=simulated
# RAZORPAY_KEY_ID="rzp_test_..."
# RAZORPAY_KEY_SECRET="<secret>"
# RAZORPAY_WEBHOOK_SECRET="<webhook-secret>"

# ── CORS (production) ─────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins in production.
# Leave empty for development (all origins allowed).
# ALLOWED_ORIGINS="https://your-domain.com,https://www.your-domain.com"

# ── Proxy trust (Render/Railway/Heroku/Nginx) ─────────────────────────────────
# Set to "true" when the backend sits behind a reverse proxy.
# TRUST_PROXY=true

# ── Cloudinary (optional) ────────────────────────────────────────────────────
# When set, media uploads are stored in Cloudinary. Format:
#   cloudinary://api_key:api_secret@cloud_name
# When not set, upload endpoint falls back to URL passthrough (no cloud storage).
# CLOUDINARY_URL="cloudinary://123456789012345:AbCdEfGhIjKlMnOpQrStUvWxYz@your_cloud_name"

# ── Redis (optional) ─────────────────────────────────────────────────────────
# When set, cache writes are persisted to Redis (write-through) and the in-memory
# cache is pre-warmed from Redis on startup. Falls back to in-memory only.
# REDIS_URL="redis://localhost:6379"
# REDIS_URL="rediss://:<password>@<host>:6380"   # TLS (e.g. Redis Cloud)

# ── Email / SMTP (optional) ──────────────────────────────────────────────────
# When all four vars are set, transactional emails (order confirmation, password
# reset, email verification) are sent via SMTP. Otherwise logged to console.
# SMTP_HOST="smtp.resend.com"
# SMTP_PORT="465"
# SMTP_USER="resend"
# SMTP_PASS="re_your_api_key"
# EMAIL_FROM="noreply@celebstyle.in"
# APP_BASE_URL="https://celebstyle.in"

# ── AI/Embeddings (optional) ───────────────────────────────────────────────────
# If set, uses OpenAI text-embedding-3-small for product embeddings.
# If not set, falls back to deterministic bag-of-words embeddings (always available).
# OPENAI_API_KEY="sk-..."

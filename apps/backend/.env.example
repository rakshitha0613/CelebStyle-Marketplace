# Copy this file to .env and fill in your values

# ── Required (validated at startup) ──────────────────────────────────────────
PORT=4000

# ── Required for persistence (Sprint 2 — Prisma migration) ───────────────────
# SQLite (dev default)
DATABASE_URL="file:./prisma/dev.db"
# PostgreSQL (production)
# DATABASE_URL="postgresql://<user>:<password>@<host>:5432/celebstyle"

# ── Required for authentication (Sprint 1.x — Auth) ──────────────────────────
JWT_SECRET="<replace-with-a-long-random-secret>"

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── ENUMS ────────────────────────────────────────────────────────────────────

enum UserRole {
  CUSTOMER
  CELEBRITY
  ADMIN
  SUPER_ADMIN
  MANUFACTURER_PARTNER
  CELEBRITY_MANAGER
  CONTENT_MODERATOR
  ANALYST
}

enum Industry {
  BOLLYWOOD
  TOLLYWOOD
  KOLLYWOOD
  MOLLYWOOD
  HOLLYWOOD
  OTT
  MUSIC
  SPORTS
  FASHION
  POLITICS
  OTHER
}

enum Occasion {
  PARTY
  WEDDING
  FESTIVAL
  CASUAL
  AWARD
  PREMIERE
  ENDORSEMENT
  FILM
  CORPORATE
  SPORTS
}

enum OrderStatus {
  AWAITING_PAYMENT
  PLACED
  CONFIRMED
  PRODUCTION_STARTED
  QUALITY_CHECK
  SHIPPED
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
  RETURN_REQUESTED
  RETURN_PICKED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  AUTHORIZED
  CAPTURED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
  DISPUTED
  CANCELLED
}

enum PaymentProvider {
  RAZORPAY
  STRIPE
  PAYU
  CASHFREE
  SIMULATED
}

enum PaymentMethod {
  UPI
  CARD
  NET_BANKING
  WALLET
  EMI
  COD
}

enum ReturnReason {
  SIZE_ISSUE
  QUALITY_ISSUE
  WRONG_ITEM
  NOT_AS_DESCRIBED
  DAMAGED
  CHANGED_MIND
  OTHER
}

enum ReturnStatus {
  REQUESTED
  APPROVED
  REJECTED
  PICKED_UP
  RECEIVED
  REFUND_INITIATED
  REFUND_COMPLETED
}

enum MediaType {
  IMAGE
  VIDEO
  DOCUMENT
  AUDIO
}

enum NotificationType {
  ORDER_PLACED
  ORDER_SHIPPED
  ORDER_DELIVERED
  ORDER_CANCELLED
  PAYMENT_SUCCESS
  PAYMENT_FAILED
  WISHLIST_RESTOCK
  PRICE_DROP
  NEW_COLLECTION
  REVIEW_APPROVED
  COMMUNITY_LIKE
  COMMUNITY_COMMENT
  FOLLOW
  SYSTEM
  PROMOTION
  RETURN_UPDATE
}

enum AnalyticsEventType {
  PAGE_VIEW
  PRODUCT_VIEW
  SEARCH
  ADD_TO_CART
  REMOVE_FROM_CART
  CHECKOUT_START
  PURCHASE
  ADD_TO_WISHLIST
  REMOVE_FROM_WISHLIST
  SHARE
  REVIEW_SUBMIT
  TRY_ON
  AR_SESSION
  RECOMMENDATION_CLICK
  FILTER_APPLY
  SCROLL_DEPTH
  SESSION_END
}

enum StockMovementType {
  INBOUND
  OUTBOUND
  RETURN
  ADJUSTMENT
  TRANSFER
  WRITE_OFF
  RESERVATION
  RELEASE
}

enum ReservationStatus {
  RESERVED
  ALLOCATED
  RELEASED
  DEDUCTED
  CANCELLED
}

enum RoutingStatus {
  PENDING
  ASSIGNED
  ACCEPTED
  IN_PRODUCTION
  QUALITY_PASSED
  DISPATCHED
}

enum AIModelType {
  SIZE_ESTIMATOR
  RECOMMENDATION
  STYLE_MATCH
  TREND_PREDICTION
  PRICE_OPTIMIZER
}

enum CouponType {
  PERCENTAGE
  FIXED_AMOUNT
  FREE_SHIPPING
  BUY_X_GET_Y
  FIRST_ORDER
}

enum SettlementStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  ON_HOLD
}

enum RefundType {
  FULL
  PARTIAL
  AUTOMATIC
  MANUAL
  GATEWAY
}

enum AddressType {
  HOME
  OFFICE
  OTHER
}

enum PermissionAction {
  CREATE
  READ
  UPDATE
  DELETE
  PUBLISH
  APPROVE
  EXPORT
  IMPERSONATE
}

enum PermissionResource {
  CELEBRITY
  OUTFIT
  MANUFACTURER
  ORDER
  USER
  REVIEW
  COMMUNITY
  COUPON
  ANALYTICS
  AUDIT
  SYSTEM
  STOREFRONT
  RETURN
  PAYMENT
}

enum LoyaltyTransactionType {
  EARN
  REDEEM
  EXPIRE
  BONUS
  ADJUSTMENT
}

enum RecommendationFeedbackType {
  IMPRESSION
  CLICK
  DISMISS
  WISHLIST
  ADD_TO_CART
  PURCHASE
  HIDE
  SKIP
  CONVERSION
}

enum ModelStatus {
  REGISTERED
  VALIDATING
  ACTIVE
  SHADOW
  DEPRECATED
  ARCHIVED
}

enum DeploymentType {
  BLUE_GREEN
  CANARY
  SHADOW
  PINNED
}

enum DeploymentStatus {
  ACTIVE
  ROLLED_BACK
  SUPERSEDED
}

enum AlertSeverity {
  INFO
  WARNING
  CRITICAL
}

// ─── GROUP A: IDENTITY & ACCESS ───────────────────────────────────────────────

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  passwordHash     String
  name             String
  phone            String?
  role             UserRole  @default(CUSTOMER)
  emailVerified    Boolean   @default(false)
  phoneVerified    Boolean   @default(false)
  twoFactorEnabled Boolean   @default(false)
  twoFactorSecret  String?
  isActive          Boolean   @default(true)
  deletedAt         DateTime?
  lastLoginAt       DateTime?
  passwordChangedAt DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  profile            UserProfile?
  userRoles          UserRoleAssignment[]
  sessions           Session[]
  emailVerifications EmailVerification[]
  passwordResets     PasswordReset[]
  addresses          Address[]
  orders             Order[]
  cart               Cart?
  wishlists          Wishlist[]
  reviews            Review[]
  communityPosts     CommunityPost[]
  comments           Comment[]
  likes              Like[]
  bookmarks          Bookmark[]
  following          Follower[]           @relation("UserFollowing")
  followers          Follower[]           @relation("UserFollowers")
  celebrityFollows   CelebrityFollower[]
  notifications      Notification[]
  loyaltyAccount     LoyaltyAccount?
  sizeProfile        SizeProfile?
  searchHistory      SearchHistory[]
  embedding          UserEmbedding?
  featureStore       UserFeatureStore?
  recommendations    Recommendation[]
  tryOnHistory       AITryOnHistory[]
  arSessions         ARSession[]
  returns            Return[]
  couponUsages           CouponUsage[]
  analyticsEvents        AnalyticsEvent[]
  settlements            Settlement[]          @relation("SettlementSettledBy")
  blogPosts              BlogPost[]
  savedLooks             SavedLook[]
  priceAlerts            PriceAlert[]
  celebrityFollowAlerts  CelebrityFollowAlert[]
  bulkOrders             BulkOrder[]
  weddingOrders          WeddingOrder[]
  customizationRequests  CustomizationRequest[]
  celebrityRatings       CelebrityRating[]
}

model UserProfile {
  id                  String    @id @default(cuid())
  userId              String    @unique
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  avatarUrl           String?
  bio                 String?   @db.Text
  dateOfBirth         DateTime?
  gender              String?
  preferredIndustries String[]
  preferredOccasions  String[]
  preferredCategories String[]
  stylePersonality    String[]
  preferredSizes      Json?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

model Role {
  id          String               @id @default(cuid())
  name        UserRole             @unique
  displayName String
  description String?
  isSystem    Boolean              @default(true)
  createdAt   DateTime             @default(now())
  permissions RolePermission[]
  userRoles   UserRoleAssignment[]
}

model Permission {
  id          String             @id @default(cuid())
  action      PermissionAction
  resource    PermissionResource
  description String?
  createdAt   DateTime           @default(now())
  roles       RolePermission[]

  @@unique([action, resource])
}

model RolePermission {
  id           String     @id @default(cuid())
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@unique([roleId, permissionId])
}

// Junction model — named UserRoleAssignment to avoid conflict with UserRole enum
model UserRoleAssignment {
  id           String   @id @default(cuid())
  userId       String
  roleId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role         Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  assignedAt   DateTime @default(now())
  assignedById String?

  @@unique([userId, roleId])
}

model Session {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshToken String    @unique
  deviceInfo   String?
  ipAddress    String?
  expiresAt    DateTime
  revokedAt    DateTime?
  createdAt    DateTime  @default(now())
}

model EmailVerification {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  revokedAt DateTime?
  createdAt DateTime  @default(now())
}

model PasswordReset {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  revokedAt DateTime?
  createdAt DateTime  @default(now())
}

// ─── GROUP B: CELEBRITY ────────────────────────────────────────────────────────

model Celebrity {
  id          String    @id @default(cuid())
  slug        String    @unique
  name        String
  industry    Industry
  isVerified  Boolean   @default(false)
  isActive    Boolean   @default(true)
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  createdById String?
  updatedById String?

  profile     CelebrityProfile?
  products    Product[]
  storefront  Storefront?
  followers   CelebrityFollower[]
  ratings     CelebrityRating[]
  mediaAssets MediaAsset[]
}

model CelebrityProfile {
  id              String    @id @default(cuid())
  celebrityId     String    @unique
  celebrity       Celebrity @relation(fields: [celebrityId], references: [id], onDelete: Cascade)
  bio             String    @db.Text
  profileImage    String    @default("")
  bannerImage     String    @default("")
  styleTags       String[]
  birthYear       Int?
  nationality     String?
  awards          String[]
  instagramHandle String?
  twitterHandle   String?
  websiteUrl      String?
  imdbUrl         String?
  debutYear       Int?
  totalLooks      Int       @default(0)
  followerCount   Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model CelebrityFollower {
  id          String    @id @default(cuid())
  userId      String
  celebrityId String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  celebrity   Celebrity @relation(fields: [celebrityId], references: [id], onDelete: Cascade)
  followedAt  DateTime  @default(now())

  @@unique([userId, celebrityId])
}

model CelebrityRating {
  id          String    @id @default(cuid())
  userId      String
  celebrityId String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  celebrity   Celebrity @relation(fields: [celebrityId], references: [id], onDelete: Cascade)
  rating      Int
  review      String?   @db.Text
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([userId, celebrityId])
  @@index([celebrityId])
}

// ─── GROUP C: PRODUCTS ────────────────────────────────────────────────────────

model Product {
  id               String    @id @default(cuid())
  slug             String    @unique
  celebrityId      String
  celebrity        Celebrity @relation(fields: [celebrityId], references: [id], onDelete: Restrict)
  brandId          String?
  brand            Brand?    @relation(fields: [brandId], references: [id], onDelete: SetNull)
  movieName        String
  occasion         Occasion
  category         String
  colorPalette     String    @default("")
  basePrice        Int
  imageUrl         String    @default("")
  description      String    @default("") @db.Text
  year             Int?
  characterName    String?
  fabricDetails    String?
  careInstructions String?
  isPublished      Boolean   @default(false)
  isActive         Boolean   @default(true)
  deletedAt        DateTime?
  publishedAt      DateTime?
  viewCount        Int       @default(0)
  wishlistCount    Int       @default(0)
  orderCount       Int       @default(0)
  averageRating    Decimal?  @db.Decimal(3, 2)
  reviewCount      Int       @default(0)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  createdById      String?
  updatedById      String?
  deletedById      String?

  images                ProductImage[]
  variants              ProductVariant[]
  manufacturerLinks     ManufacturerProduct[]
  categories            ProductCategory[]
  tags                  ProductTag[]
  collections           CollectionProduct[]
  orderItems            OrderItem[]
  wishlistItems         WishlistItem[]
  cartItems             CartItem[]
  inventory             Inventory[]
  reviews               Review[]
  recommendations       Recommendation[]
  featuredInStorefronts StorefrontFeaturedProduct[]
  bookmarks             Bookmark[]
  searchClicks          SearchHistory[]
  mediaAssets           MediaAsset[]
  tryOnHistory          AITryOnHistory[]
  arSessions            ARSession[]
  communityPosts        CommunityPost[]
  analyticsEvents       AnalyticsEvent[]
  embedding             ProductEmbedding?
  trendingEntry         TrendingProduct?
  featureStore          ProductFeatureStore?
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  altText   String?
  sortOrder Int      @default(0)
  isPrimary Boolean  @default(false)
  width     Int?
  height    Int?
  assetId   String?
  createdAt DateTime @default(now())
}

model ProductVariant {
  id              String         @id @default(cuid())
  productId       String
  product         Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  sku             String         @unique
  size            String
  color           String?
  priceAdjustment Int            @default(0)
  isAvailable     Boolean        @default(true)
  sortOrder       Int            @default(0)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  inventory       Inventory[]
  cartItems       CartItem[]
  wishlistItems   WishlistItem[]
  orderItems      OrderItem[]

  @@unique([productId, size, color])
}

model Category {
  id          String            @id @default(cuid())
  slug        String            @unique
  name        String
  description String?
  parentId    String?
  parent      Category?         @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children    Category[]        @relation("CategoryHierarchy")
  imageUrl    String?
  sortOrder   Int               @default(0)
  isActive    Boolean           @default(true)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  products    ProductCategory[]
}

model ProductCategory {
  id         String   @id @default(cuid())
  productId  String
  categoryId String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  isPrimary  Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@unique([productId, categoryId])
}

model Brand {
  id          String    @id @default(cuid())
  slug        String    @unique
  name        String
  logoUrl     String?
  websiteUrl  String?
  description String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]
}

model Collection {
  id            String              @id @default(cuid())
  slug          String              @unique
  name          String
  description   String?             @db.Text
  coverImageUrl String?
  isPublished   Boolean             @default(false)
  publishedAt   DateTime?
  startsAt      DateTime?
  endsAt        DateTime?
  sortOrder     Int                 @default(0)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  createdById   String?
  products      CollectionProduct[]
}

model CollectionProduct {
  id           String     @id @default(cuid())
  collectionId String
  productId    String
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  product      Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  sortOrder    Int        @default(0)
  addedAt      DateTime   @default(now())

  @@unique([collectionId, productId])
}

model Tag {
  id         String       @id @default(cuid())
  slug       String       @unique
  name       String
  category   String?
  usageCount Int          @default(0)
  createdAt  DateTime     @default(now())
  products   ProductTag[]
}

model ProductTag {
  id        String   @id @default(cuid())
  productId String
  tagId     String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)
  addedAt   DateTime @default(now())

  @@unique([productId, tagId])
}

// ─── GROUP D: MANUFACTURER ────────────────────────────────────────────────────

model Manufacturer {
  id           String    @id @default(cuid())
  slug         String    @unique
  name         String
  location     String
  rating       Decimal   @default(0) @db.Decimal(3, 2)
  contactEmail String
  verified     Boolean   @default(false)
  isActive     Boolean   @default(true)
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  verifiedById String?
  verifiedAt   DateTime?

  profile      ManufacturerProfile?
  productLinks ManufacturerProduct[]
  routings     ManufacturerRouting[]
}

model ManufacturerProfile {
  id               String       @id @default(cuid())
  manufacturerId   String       @unique
  manufacturer     Manufacturer @relation(fields: [manufacturerId], references: [id], onDelete: Cascade)
  description      String?      @db.Text
  specialties      String[]
  gstin            String?
  panNumber        String?
  annualCapacity   Int?
  minOrderQuantity Int?
  leadTimeDays     Int?
  certifications   String[]
  websiteUrl       String?
  portfolioUrls    String[]
  city             String?
  state            String?
  pincode          String?
  country          String       @default("India")
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
}

model ManufacturerProduct {
  id             String       @id @default(cuid())
  productId      String
  manufacturerId String
  product        Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  manufacturer   Manufacturer @relation(fields: [manufacturerId], references: [id], onDelete: Restrict)
  isPrimary      Boolean      @default(false)
  priority       Int          @default(0)
  createdAt      DateTime     @default(now())

  @@unique([productId, manufacturerId])
}

// ─── GROUP E: INVENTORY ───────────────────────────────────────────────────────

model Warehouse {
  id           String      @id @default(cuid())
  slug         String      @unique
  name         String
  city         String
  state        String
  pincode      String
  country      String      @default("India")
  contactPhone String?
  priority     Int         @default(100)
  isActive     Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  inventory    Inventory[]
  reservations InventoryReservation[]
}

model Inventory {
  id                String          @id @default(cuid())
  productId         String
  variantId         String
  warehouseId       String
  product           Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant           ProductVariant  @relation(fields: [variantId], references: [id], onDelete: Cascade)
  warehouse         Warehouse       @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  quantity          Int             @default(0)
  reservedQuantity  Int             @default(0)
  lowStockThreshold Int             @default(5)
  updatedAt         DateTime               @updatedAt
  movements         StockMovement[]
  reservations      InventoryReservation[]

  @@unique([variantId, warehouseId])
}

model StockMovement {
  id             String            @id @default(cuid())
  inventoryId    String
  inventory      Inventory         @relation(fields: [inventoryId], references: [id], onDelete: Restrict)
  type           StockMovementType
  quantityChange Int
  quantityBefore Int
  quantityAfter  Int
  referenceId    String?
  referenceType  String?
  notes          String?
  createdAt      DateTime          @default(now())
  createdById    String?
}

// ─── GROUP F: COMMERCE ────────────────────────────────────────────────────────

model Address {
  id        String      @id @default(cuid())
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      AddressType @default(HOME)
  label     String?
  fullName  String
  phone     String
  line1     String
  line2     String?
  city      String
  state     String
  pincode   String
  country   String      @default("India")
  isDefault         Boolean     @default(false)
  isDefaultShipping Boolean     @default(false)
  isDefaultBilling  Boolean     @default(false)
  isActive          Boolean     @default(true)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  orders            Order[]
}

model Cart {
  id             String     @id @default(cuid())
  userId         String     @unique
  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  couponId       String?
  coupon         Coupon?    @relation(fields: [couponId], references: [id], onDelete: SetNull)
  discountAmount Int        @default(0)
  expiresAt      DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  items          CartItem[]
}

model CartItem {
  id              String          @id @default(cuid())
  cartId          String
  productId       String
  variantId       String?
  cart            Cart            @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product         Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant         ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)
  size            String          @default("M")
  color           String?
  quantity        Int             @default(1)
  priceAtAdd      Int
  productSnapshot Json?
  addedAt         DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@unique([cartId, productId, size])
}

model Order {
  id              String        @id @default(cuid())
  orderNumber     String        @unique
  userId          String?
  user            User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  addressId       String?
  address         Address?      @relation(fields: [addressId], references: [id], onDelete: SetNull)
  shippingName    String
  shippingPhone   String
  shippingAddress String        @db.Text
  shippingCity    String
  shippingState   String
  shippingPincode String
  customerEmail   String
  subtotal        Int
  discountAmount  Int           @default(0)
  shippingAmount  Int
  taxAmount       Int           @default(0)
  total           Int
  status          OrderStatus   @default(PLACED)
  paymentStatus   PaymentStatus @default(PENDING)
  couponId        String?
  coupon          Coupon?       @relation(fields: [couponId], references: [id], onDelete: SetNull)
  couponCode       String?
  idempotencyKey   String?
  taxSnapshot      Json?
  shippingSnapshot Json?
  couponSnapshot   Json?
  notes            String?
  internalNotes    String?       @db.Text
  cancelledAt     DateTime?
  cancelReason    String?
  deliveredAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  items                 OrderItem[]
  commission            OrderCommission?
  routing               ManufacturerRouting[]
  payments              Payment[]
  inventoryReservations InventoryReservation[]
  invoice         Invoice?
  returns         Return[]
  refunds         Refund[]
  couponUsage     CouponUsage?
  analyticsEvents AnalyticsEvent[]
  settlement      Settlement?
}

model OrderItem {
  id              String               @id @default(cuid())
  orderId         String
  productId       String
  variantId       String?
  order           Order                @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product         Product              @relation(fields: [productId], references: [id], onDelete: Restrict)
  variant         ProductVariant?      @relation(fields: [variantId], references: [id], onDelete: SetNull)
  productSlug     String
  productName     String
  celebrityId     String
  celebrityName   String
  category        String
  size            String
  imageUrl        String
  unitPrice       Int
  quantity        Int                  @default(1)
  totalPrice      Int
  manufacturerIds       String[]
  routing               ManufacturerRouting?
  returnItems           ReturnItem[]
  inventoryReservations InventoryReservation[]
}

model OrderCommission {
  id                  String    @id @default(cuid())
  orderId             String    @unique
  order               Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  platformFee         Int
  celebrityCommission Int
  manufacturerShare   Int
  platformFeePercent  Decimal   @db.Decimal(5, 2)
  celebrityPercent    Decimal   @db.Decimal(5, 2)
  manufacturerPercent Decimal   @db.Decimal(5, 2)
  settledAt           DateTime?
  settledById         String?
}

model ManufacturerRouting {
  id               String        @id @default(cuid())
  orderId          String
  orderItemId      String        @unique
  manufacturerId   String?
  order            Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderItem        OrderItem     @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  manufacturer     Manufacturer? @relation(fields: [manufacturerId], references: [id], onDelete: SetNull)
  manufacturerName String
  status           RoutingStatus @default(PENDING)
  assignedAt       DateTime?
  acceptedAt       DateTime?
  dispatchedAt     DateTime?
  trackingCode     String?
  notes            String?
}

model Payment {
  id                String          @id @default(cuid())
  orderId           String
  order             Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  provider          PaymentProvider
  method            PaymentMethod
  providerPaymentId String?         @unique
  providerOrderId   String?
  amount            Int
  currency          String          @default("INR")
  status            PaymentStatus   @default(PENDING)
  gatewayResponse   Json?
  errorCode         String?
  errorMessage      String?
  capturedAt        DateTime?
  refundedAmount    Int             @default(0)
  metadata          Json?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  refunds           Refund[]
}

model InventoryReservation {
  id          String            @id @default(cuid())
  orderId     String
  orderItemId String
  inventoryId String
  warehouseId String
  variantId   String
  quantity    Int
  status      ReservationStatus @default(RESERVED)
  reservedAt  DateTime          @default(now())
  allocatedAt DateTime?
  releasedAt  DateTime?
  deductedAt  DateTime?

  order     Order     @relation(fields: [orderId],     references: [id], onDelete: Cascade)
  orderItem OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  inventory Inventory @relation(fields: [inventoryId], references: [id], onDelete: Restrict)
  warehouse Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([inventoryId])
  @@index([status])
}

model WebhookEvent {
  id          String   @id @default(cuid())
  provider    String
  eventId     String
  eventType   String
  orderId     String?
  paymentId   String?
  processedAt DateTime @default(now())

  @@unique([provider, eventId])
}

model Invoice {
  id               String   @id @default(cuid())
  orderId          String   @unique
  order            Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  invoiceNumber    String   @unique
  invoiceUrl       String?
  taxBreakdown     Json?
  orderSnapshot    Json?
  customerSnapshot Json?
  issuedAt         DateTime @default(now())
}

model Return {
  id            String       @id @default(cuid())
  orderId       String
  userId        String
  order         Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  reason        ReturnReason
  status        ReturnStatus @default(REQUESTED)
  description   String?      @db.Text
  imageUrls     String[]
  refundAmount  Int?
  pickupAddress String?      @db.Text
  trackingCode  String?
  requestedAt   DateTime     @default(now())
  approvedAt    DateTime?
  approvedById  String?
  completedAt   DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  items         ReturnItem[]
  refund        Refund?
}

model ReturnItem {
  id          String    @id @default(cuid())
  returnId    String
  orderItemId String
  return      Return    @relation(fields: [returnId], references: [id], onDelete: Cascade)
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Restrict)
  quantity    Int       @default(1)
  reason      String?
}

model Refund {
  id               String        @id @default(cuid())
  returnId         String?       @unique
  orderId          String
  paymentId        String
  return           Return?       @relation(fields: [returnId], references: [id], onDelete: SetNull)
  order            Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  payment          Payment       @relation(fields: [paymentId], references: [id], onDelete: Restrict)
  amount           Int
  currency         String        @default("INR")
  type             RefundType    @default(FULL)
  providerRefundId String?       @unique
  status           PaymentStatus @default(PENDING)
  processedAt      DateTime?
  processedById    String?
  notes            String?
  createdAt        DateTime      @default(now())
}

model Settlement {
  id                    String           @id @default(cuid())
  orderId               String           @unique
  order                 Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  platformFee           Int
  celebrityCommission   Int
  manufacturerShare     Int
  taxDeducted           Int              @default(0)
  netCelebrityAmount    Int
  netManufacturerAmount Int
  status                SettlementStatus @default(PENDING)
  settledAt             DateTime?
  settledById           String?
  settledBy             User?            @relation("SettlementSettledBy", fields: [settledById], references: [id], onDelete: SetNull)
  notes                 String?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
}

model Coupon {
  id                    String        @id @default(cuid())
  code                  String        @unique
  type                  CouponType
  value                 Int
  minOrderAmount        Int           @default(0)
  maxDiscountAmount     Int?
  usageLimit            Int?
  usageLimitPerUser     Int           @default(1)
  usedCount             Int           @default(0)
  startsAt              DateTime
  expiresAt             DateTime?
  isActive              Boolean       @default(true)
  applicableProductIds  String[]
  applicableCategoryIds String[]
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  createdById           String?
  carts                 Cart[]
  orders                Order[]
  usages                CouponUsage[]
}

model CouponUsage {
  id              String   @id @default(cuid())
  couponId        String
  userId          String
  orderId         String   @unique
  coupon          Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  discountApplied Int
  usedAt          DateTime @default(now())
}

// ─── GROUP G: SOCIAL & COMMUNITY ─────────────────────────────────────────────

model Wishlist {
  id        String         @id @default(cuid())
  userId    String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String         @default("My Wishlist")
  isDefault Boolean        @default(true)
  isPublic  Boolean        @default(false)
  createdAt DateTime       @default(now())
  items     WishlistItem[]
}

model WishlistItem {
  id         String          @id @default(cuid())
  wishlistId String
  productId  String
  variantId  String?
  wishlist   Wishlist        @relation(fields: [wishlistId], references: [id], onDelete: Cascade)
  product    Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant    ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  addedAt    DateTime        @default(now())

  @@unique([wishlistId, productId])
}

model Review {
  id                 String        @id @default(cuid())
  userId             String
  productId          String
  orderId            String?
  orderItemId        String?
  user               User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  product            Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  rating             Int
  title              String?
  body               String        @db.Text
  isVerifiedPurchase Boolean       @default(false)
  isApproved         Boolean       @default(false)
  approvedAt         DateTime?
  approvedById       String?
  helpfulCount       Int           @default(0)
  unhelpfulCount     Int           @default(0)
  deletedAt          DateTime?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  images             ReviewImage[]

  @@unique([userId, productId])
}

model ReviewImage {
  id        String   @id @default(cuid())
  reviewId  String
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  url       String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
}

model ReviewHelpful {
  id        String   @id @default(cuid())
  reviewId  String
  userId    String
  createdAt DateTime @default(now())

  @@unique([reviewId, userId])
}

model Follower {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  follower    User     @relation("UserFollowing", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("UserFollowers", fields: [followingId], references: [id], onDelete: Cascade)
  followedAt  DateTime @default(now())

  @@unique([followerId, followingId])
}

model CommunityPost {
  id            String               @id @default(cuid())
  userId        String
  productId     String?
  user          User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  product       Product?             @relation(fields: [productId], references: [id], onDelete: SetNull)
  caption       String               @db.Text
  tags          String[]
  isApproved    Boolean              @default(false)
  approvedAt    DateTime?
  approvedById  String?
  likeCount     Int                  @default(0)
  commentCount  Int                  @default(0)
  bookmarkCount Int                  @default(0)
  deletedAt     DateTime?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  images        CommunityPostImage[]
  likes         Like[]
  comments      Comment[]
  bookmarks     Bookmark[]
}

model CommunityPostImage {
  id        String        @id @default(cuid())
  postId    String
  post      CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  url       String
  sortOrder Int           @default(0)
  createdAt DateTime      @default(now())
}

model Comment {
  id         String        @id @default(cuid())
  postId     String
  userId     String
  parentId   String?
  post       CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent     Comment?      @relation("CommentReplies", fields: [parentId], references: [id], onDelete: SetNull)
  replies    Comment[]     @relation("CommentReplies")
  body       String        @db.Text
  isApproved Boolean       @default(true)
  likeCount  Int           @default(0)
  deletedAt  DateTime?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  likes      Like[]
}

model Like {
  id        String         @id @default(cuid())
  userId    String
  postId    String?
  commentId String?
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      CommunityPost? @relation(fields: [postId], references: [id], onDelete: Cascade)
  comment   Comment?       @relation(fields: [commentId], references: [id], onDelete: Cascade)
  createdAt DateTime       @default(now())

  @@unique([userId, postId])
  @@unique([userId, commentId])
}

model Bookmark {
  id        String         @id @default(cuid())
  userId    String
  postId    String?
  productId String?
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      CommunityPost? @relation(fields: [postId], references: [id], onDelete: Cascade)
  product   Product?       @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime       @default(now())

  @@unique([userId, postId])
  @@unique([userId, productId])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  body      String
  isRead    Boolean          @default(false)
  metadata  Json?
  actionUrl String?
  readAt    DateTime?
  createdAt DateTime         @default(now())
}

model LoyaltyAccount {
  id             String               @id @default(cuid())
  userId         String               @unique
  user           User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  points         Int                  @default(0)
  lifetimePoints Int                  @default(0)
  tier           String               @default("Bronze")
  tierUpdatedAt  DateTime?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  transactions   LoyaltyTransaction[]
}

model LoyaltyTransaction {
  id            String                 @id @default(cuid())
  accountId     String
  account       LoyaltyAccount         @relation(fields: [accountId], references: [id], onDelete: Cascade)
  type          LoyaltyTransactionType
  points        Int
  balanceAfter  Int
  referenceId   String?
  referenceType String?
  description   String?
  expiresAt     DateTime?
  createdAt     DateTime               @default(now())
}

// ─── GROUP H: DISCOVERY & AI ─────────────────────────────────────────────────

model SearchHistory {
  id               String   @id @default(cuid())
  userId           String?
  user             User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionId        String?
  query            String
  filters          Json?
  resultCount      Int?
  clickedProductId String?
  clickedProduct   Product? @relation(fields: [clickedProductId], references: [id], onDelete: SetNull)
  createdAt        DateTime @default(now())
}

model Recommendation {
  id          String    @id @default(cuid())
  userId      String
  productId   String
  modelId     String?
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  model       AIModel?  @relation(fields: [modelId], references: [id], onDelete: SetNull)
  score       Decimal   @db.Decimal(5, 4)
  reason      String?
  context     String?
  wasClicked  Boolean   @default(false)
  wasOrdered  Boolean   @default(false)
  generatedAt DateTime  @default(now())
  expiresAt   DateTime?

  @@unique([userId, productId, context])
}

model SizeProfile {
  id             String    @id @default(cuid())
  userId         String    @unique
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  height         Decimal?  @db.Decimal(5, 1)
  weight         Decimal?  @db.Decimal(5, 1)
  chest          Decimal?  @db.Decimal(5, 1)
  waist          Decimal?  @db.Decimal(5, 1)
  hips           Decimal?  @db.Decimal(5, 1)
  shoulderWidth  Decimal?  @db.Decimal(5, 1)
  inseam         Decimal?  @db.Decimal(5, 1)
  sizeChart      Json?
  bodyType       String?
  confidence     Decimal?  @db.Decimal(3, 2)
  lastMeasuredAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model AIModel {
  id              String           @id @default(cuid())
  name            String
  type            AIModelType
  version         String
  provider        String?
  endpoint        String?
  isActive        Boolean          @default(true)
  accuracy        Decimal?         @db.Decimal(5, 4)
  deployedAt      DateTime         @default(now())
  deprecatedAt    DateTime?
  metadata        Json?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  recommendations Recommendation[]
  tryOnHistory    AITryOnHistory[]
}

model AITryOnHistory {
  id               String   @id @default(cuid())
  userId           String?
  productId        String
  modelId          String?
  user             User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  product          Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  model            AIModel? @relation(fields: [modelId], references: [id], onDelete: SetNull)
  inputImageUrl    String?
  resultImageUrl   String?
  processingTimeMs Int?
  success          Boolean
  errorMessage     String?
  feedbackRating   Int?
  wasAddedToCart   Boolean  @default(false)
  createdAt        DateTime @default(now())
}

model ARSession {
  id              String   @id @default(cuid())
  userId          String?
  productId       String
  user            User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  product         Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  deviceType      String?
  platform        String?
  durationSeconds Int?
  wasAddedToCart  Boolean  @default(false)
  screenshotUrl   String?
  createdAt       DateTime @default(now())
}

// ─── GROUP H2: AI VECTOR STORE ───────────────────────────────────────────────

model ProductEmbedding {
  id           String                      @id @default(cuid())
  productId    String                      @unique
  product      Product                     @relation(fields: [productId], references: [id], onDelete: Cascade)
  embedding    Unsupported("vector(1536)")
  modelVersion String                      @default("v1-deterministic")
  tokenCount   Int?
  updatedAt    DateTime                    @updatedAt
  createdAt    DateTime                    @default(now())
}

model UserEmbedding {
  id           String                      @id @default(cuid())
  userId       String                      @unique
  user         User                        @relation(fields: [userId], references: [id], onDelete: Cascade)
  embedding    Unsupported("vector(1536)")
  modelVersion String                      @default("v1-deterministic")
  signalCount  Int                         @default(0)
  updatedAt    DateTime                    @updatedAt
  createdAt    DateTime                    @default(now())
}

// Pre-computed co-purchase pairs (maintained by application via $queryRaw)
model CoPurchasedPair {
  productAId      String
  productBId      String
  coPurchaseCount Int      @default(1)
  updatedAt       DateTime @updatedAt

  @@id([productAId, productBId])
}

// Pre-computed co-view pairs (maintained by application via $queryRaw)
model CoviewedPair {
  productAId  String
  productBId  String
  coviewCount Int      @default(1)
  updatedAt   DateTime @updatedAt

  @@id([productAId, productBId])
}

// Pre-computed rolling trending scores (refreshed every 15 min by worker)
model TrendingProduct {
  id        String   @id @default(cuid())
  productId String   @unique
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  score     Decimal  @db.Decimal(12, 4)
  window    String   @default("7d")
  rank      Int
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

// Append-only impression log per recommendation served (no FK constraints — high-write)
model RecommendationImpression {
  id           String   @id @default(cuid())
  userId       String?
  sessionId    String?
  productId    String
  context      String
  position     Int
  modelId      String?
  wasClicked   Boolean  @default(false)
  dwellTimeMs  Int?
  experimentId String?
  variant      String?
  createdAt    DateTime @default(now())
}

// Append-only recommendation feedback log (no FK constraints — high-write)
model RecommendationFeedback {
  id           String                     @id @default(cuid())
  userId       String?
  sessionId    String?
  productId    String
  feedbackType RecommendationFeedbackType
  context      String?
  position     Int?
  experimentId String?
  variant      String?
  revenue      Decimal?                   @db.Decimal(12, 2)
  metadata     Json?
  createdAt    DateTime                   @default(now())

  @@index([userId, feedbackType])
  @@index([productId, feedbackType])
  @@index([experimentId, variant])
  @@index([feedbackType, createdAt])
  @@index([createdAt])
}

// Sticky experiment assignments — ensures same user always gets same variant
model ExperimentAssignment {
  id           String   @id @default(cuid())
  userId       String
  experimentId String
  variant      String
  assignedAt   DateTime @default(now())

  @@unique([userId, experimentId])
  @@index([experimentId])
}

// ─── GROUP H4: AI OPERATIONS & MLOPS ─────────────────────────────────────────

// Model version registry — each row is one model version
model ModelRegistry {
  id               String        @id @default(cuid())
  name             String
  version          String
  modelType        String
  description      String?
  status           ModelStatus   @default(REGISTERED)
  trainingDate     DateTime?
  trainingDataSize Int?
  metrics          Json          @default("{}")
  hyperparams      Json          @default("{}")
  artifactPath     String?
  createdById      String?
  activatedAt      DateTime?
  deprecatedAt     DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  deployments      ModelDeployment[]
  predictions      PredictionLog[]

  @@unique([name, version])
  @@index([name, status])
  @@index([modelType, status])
}

// Deployment record — one ACTIVE row per environment at any time
model ModelDeployment {
  id              String           @id @default(cuid())
  modelId         String
  model           ModelRegistry    @relation(fields: [modelId], references: [id], onDelete: Cascade)
  deploymentType  DeploymentType   @default(BLUE_GREEN)
  environment     String           @default("production")
  status          DeploymentStatus @default(ACTIVE)
  trafficPercent  Int              @default(100)
  pinnedVersion   String?
  previousModelId String?
  deployedById    String?
  deployedAt      DateTime         @default(now())
  rolledBackAt    DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([environment, status])
  @@index([deployedAt])
}

// Prediction log — append-only, no FK constraints on userId (high-write)
model PredictionLog {
  id               String        @id @default(cuid())
  modelId          String
  model            ModelRegistry @relation(fields: [modelId], references: [id], onDelete: Cascade)
  requestId        String?
  userId           String?
  sessionId        String?
  context          String
  topN             Json
  latencyMs        Int
  cacheHit         Boolean       @default(false)
  experimentId     String?
  variant          String?
  outcomeClicked   Boolean?
  outcomePurchased Boolean?
  feedbackId       String?
  createdAt        DateTime      @default(now())

  @@index([modelId, createdAt])
  @@index([context, createdAt])
  @@index([createdAt])
  @@index([requestId])
}

// Feature distribution snapshot for drift detection
model FeatureSnapshot {
  id           String   @id @default(cuid())
  featureType  String
  snapshotAt   DateTime @default(now())
  sampleSize   Int
  mean         Float
  stddev       Float
  min          Float
  max          Float
  p25          Float
  p50          Float
  p75          Float
  p95          Float
  distribution Json

  @@index([featureType, snapshotAt])
}

// MLOps alerts — drift, latency degradation, coverage drops
model MLOpsAlert {
  id         String        @id @default(cuid())
  alertType  String
  severity   AlertSeverity
  title      String
  message    String        @db.Text
  metadata   Json          @default("{}")
  isResolved Boolean       @default(false)
  resolvedAt DateTime?
  createdAt  DateTime      @default(now())

  @@index([alertType, isResolved])
  @@index([severity, isResolved])
  @@index([createdAt])
}

// ─── GROUP I: ANALYTICS & AUDIT ───────────────────────────────────────────────

model AnalyticsEvent {
  id          String             @id @default(cuid())
  type        AnalyticsEventType
  userId      String?
  user        User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  sessionId   String?
  productId   String?
  product     Product?           @relation(fields: [productId], references: [id], onDelete: SetNull)
  orderId     String?
  order       Order?             @relation(fields: [orderId], references: [id], onDelete: SetNull)
  searchQuery String?
  page        String?
  referrer    String?
  userAgent   String?
  ipAddress   String?
  properties  Json?
  createdAt   DateTime           @default(now())
}

model AnalyticsSession {
  id          String    @id @default(cuid())
  userId      String?
  device      String?
  browser     String?
  country     String?
  state       String?
  city        String?
  referrer    String?
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  firstPage   String?
  eventCount  Int       @default(0)
  endedAt     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model AuditLog {
  id           String   @id @default(cuid())
  actorId      String?
  actorEmail   String?
  actorRole    String?
  action       String
  resourceType String
  resourceId   String
  before       Json?
  after        Json?
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())
}

model SystemSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String?
  isPublic    Boolean  @default(false)
  updatedAt   DateTime @updatedAt
  updatedById String?
}

// ─── GROUP J: CONTENT & MEDIA ─────────────────────────────────────────────────

model MediaAsset {
  id           String     @id @default(cuid())
  url          String     @unique
  type         MediaType
  mimeType     String
  filename     String
  sizeBytes    Int?
  width        Int?
  height       Int?
  altText      String?
  uploadedById String?
  celebrityId  String?
  productId    String?
  celebrity    Celebrity? @relation(fields: [celebrityId], references: [id], onDelete: SetNull)
  product      Product?   @relation(fields: [productId], references: [id], onDelete: SetNull)
  isPublic     Boolean    @default(true)
  deletedAt    DateTime?
  createdAt    DateTime   @default(now())
}

model Storefront {
  id               String                      @id @default(cuid())
  celebrityId      String                      @unique
  celebrity        Celebrity                   @relation(fields: [celebrityId], references: [id], onDelete: Cascade)
  displayName      String
  bannerImage      String                      @default("")
  message          String                      @default("") @db.Text
  verified         Boolean                     @default(false)
  commissionRate   Decimal                     @default(5.00) @db.Decimal(5, 2)
  isPublished      Boolean                     @default(false)
  publishedAt      DateTime?
  createdAt        DateTime                    @default(now())
  updatedAt        DateTime                    @updatedAt
  featuredProducts StorefrontFeaturedProduct[]
}

model StorefrontFeaturedProduct {
  id           String     @id @default(cuid())
  storefrontId String
  productId    String
  storefront   Storefront @relation(fields: [storefrontId], references: [id], onDelete: Cascade)
  product      Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  sortOrder    Int        @default(0)
  addedAt      DateTime   @default(now())

  @@unique([storefrontId, productId])
}

// ─── GROUP K: LOGISTICS ───────────────────────────────────────────────────────

model ShippingZone {
  id            String         @id @default(cuid())
  name          String
  states        String[]
  pincodeRanges Json?
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  rates         ShippingRate[]
}

model ShippingRate {
  id                    String       @id @default(cuid())
  zoneId                String
  zone                  ShippingZone @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  minOrderAmount        Int          @default(0)
  freeShippingThreshold Int?
  baseRate              Int
  perKgRate             Int          @default(0)
  estimatedDaysMin      Int
  estimatedDaysMax      Int
  isActive              Boolean      @default(true)
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
}

// ─── GROUP H3: FEATURE STORE ──────────────────────────────────────────────────

model UserFeatureStore {
  id                 String   @id @default(cuid())
  userId             String   @unique
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryAffinity   Json     @default("{}")
  celebrityAffinity  Json     @default("{}")
  brandAffinity      Json     @default("{}")
  pricePreference    Json     @default("{}")
  colorPreference    Json     @default("{}")
  occasionPreference Json     @default("{}")
  purchaseFrequency  Float    @default(0)
  recencyScore       Float    @default(0)
  monetaryScore      Float    @default(0)
  wishlistAffinity   Json     @default("{}")
  cartAffinity       Json     @default("{}")
  searchAffinity     Json     @default("{}")
  computedAt         DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model ProductFeatureStore {
  id              String   @id @default(cuid())
  productId       String   @unique
  product         Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  ctr             Float    @default(0)
  conversionRate  Float    @default(0)
  wishlistRate    Float    @default(0)
  addToCartRate   Float    @default(0)
  returnRate      Float    @default(0)
  popularityScore Float    @default(0)
  trendingScore   Float    @default(0)
  freshnessScore  Float    @default(0)
  computedAt      DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ── Sprint 9 additions ────────────────────────────────────────────────────────

model BlogPost {
  id          String    @id @default(cuid())
  slug        String    @unique
  authorId    String
  author      User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  celebrityId String?
  title       String
  summary     String    @db.Text
  body        String    @db.Text
  coverImage  String?
  tags        String[]
  productIds  String[]
  isPublished Boolean   @default(false)
  publishedAt DateTime?
  viewCount   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([isPublished, createdAt(sort: Desc)])
}

model SavedLook {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId     String?
  outfitName    String
  imageUrl      String?
  screenshotUrl String?
  notes         String?
  savedAt       DateTime @default(now())

  @@index([userId, savedAt(sort: Desc)])
}

model PriceAlert {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId   String
  outfitName  String
  targetPrice Decimal  @db.Decimal(12, 2)
  isActive    Boolean  @default(true)
  triggeredAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, productId])
  @@index([userId, isActive])
}

model CelebrityFollowAlert {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  celebrityId String
  celebrityName String
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())

  @@unique([userId, celebrityId])
  @@index([userId, isActive])
}

model StorefrontPageView {
  id          String   @id @default(cuid())
  celebrityId String
  visitorId   String
  productId   String?
  converted   Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([celebrityId, createdAt])
}

model BulkOrder {
  id              String          @id @default(cuid())
  userId          String
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName     String          @default("")
  contactName     String          @default("")
  contactEmail    String
  contactPhone    String          @default("")
  deliveryAddress String          @db.Text
  totalUnits      Int
  subtotal        Decimal         @db.Decimal(12, 2)
  discountRate    Decimal         @db.Decimal(5, 4)
  discountedTotal Decimal         @db.Decimal(12, 2)
  notes           String?         @db.Text
  status          String          @default("PENDING")
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  items           BulkOrderItem[]

  @@index([userId, createdAt(sort: Desc)])
}

model BulkOrderItem {
  id           String    @id @default(cuid())
  bulkOrderId  String
  bulkOrder    BulkOrder @relation(fields: [bulkOrderId], references: [id], onDelete: Cascade)
  productId    String
  outfitName   String
  quantity     Int
  size         String
  pricePerUnit Decimal   @db.Decimal(10, 2)
}

model WeddingOrder {
  id              String             @id @default(cuid())
  userId          String
  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  brideName       String             @default("")
  groomName       String             @default("")
  weddingDate     DateTime
  venue           String             @default("")
  contactEmail    String
  contactPhone    String             @default("")
  deliveryAddress String             @db.Text
  subtotal        Decimal            @db.Decimal(12, 2)
  rushFee         Decimal            @default(0) @db.Decimal(12, 2)
  total           Decimal            @db.Decimal(12, 2)
  stylistNote     String?            @db.Text
  status          String             @default("PENDING")
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  items           WeddingOrderItem[]

  @@index([userId, createdAt(sort: Desc)])
}

model WeddingOrderItem {
  id             String       @id @default(cuid())
  weddingOrderId String
  weddingOrder   WeddingOrder @relation(fields: [weddingOrderId], references: [id], onDelete: Cascade)
  productId      String
  outfitName     String
  quantity       Int
  size           String
  customFabric   String?
  customColour   String?
  customNotes    String?      @db.Text
  pricePerUnit   Decimal      @db.Decimal(10, 2)
}

model CustomizationRequest {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId       String
  outfitName      String
  customFabric    String?
  customColour    String?
  embroidery      Boolean  @default(false)
  embroideryText  String?
  measurements    Json     @default("{}")
  additionalNotes String?  @db.Text
  estimatedPrice  Decimal  @default(0) @db.Decimal(10, 2)
  status          String   @default("PENDING")
  quoteAmount     Decimal? @db.Decimal(10, 2)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId, createdAt(sort: Desc)])
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Celebrity {
  id           String   @id @default(cuid())
  name         String
  industry     String
  bio          String
  profileImage String
  bannerImage  String
  styleTags    String   @default("[]")
  outfits      Outfit[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Manufacturer {
  id           String   @id @default(cuid())
  name         String
  location     String
  rating       Float
  contactEmail String
  verified     Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  outfitLinks  OutfitManufacturer[]
}

model Outfit {
  id                String   @id @default(cuid())
  celebrityId       String
  celebrity         Celebrity @relation(fields: [celebrityId], references: [id], onDelete: Cascade)
  movieName         String
  occasion          String
  category          String
  colorPalette      String
  price             Int
  imageUrl          String
  description       String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  manufacturerLinks OutfitManufacturer[]
}

model OutfitManufacturer {
  id             String      @id @default(cuid())
  outfitId       String
  manufacturerId String
  outfit         Outfit      @relation(fields: [outfitId], references: [id], onDelete: Cascade)
  manufacturer   Manufacturer @relation(fields: [manufacturerId], references: [id], onDelete: Cascade)

  @@unique([outfitId, manufacturerId])
}
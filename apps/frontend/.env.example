# Copy this file to .env.local

# Backend API base URL
NEXT_PUBLIC_API_BASE_URL="http://localhost:4000"

# Virtual Try-On pilot mode (optional, dev only) — when "true", restricts
# /try-on to the 10 TRYON_PILOT_OUTFITS (see scripts/tryon-pilot/). Reversible:
# unset or "false" restores the full outfit list. No env prefix needed here —
# next.config.mjs maps it to NEXT_PUBLIC_TRYON_PILOT_MODE for the client.
# TRYON_PILOT_MODE=true

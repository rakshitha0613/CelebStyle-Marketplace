{
  "name": "celebstyle",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:frontend": "npm run dev --workspace apps/frontend",
    "dev:backend": "npm run dev --workspace apps/backend",
    "build": "npm run build --workspace apps/frontend && npm run build --workspace apps/backend",
    "build:frontend": "npm run build --workspace apps/frontend",
    "build:backend": "npm run build --workspace apps/backend",
    "start:frontend": "npm run start --workspace apps/frontend",
    "start:backend": "npm run start --workspace apps/backend",
    "typecheck": "npm run typecheck --workspace apps/frontend && npm run typecheck --workspace apps/backend",
    "test": "npm run test --workspace apps/backend",
    "dev": "concurrently --names \"backend,frontend\" --prefix-colors \"cyan,magenta\" \"npm run dev:backend\" \"npm run dev:frontend\"",
    "assets:status": "node scripts/asset-manager.mjs status",
    "assets:generate": "node --use-system-ca scripts/asset-manager.mjs generate",
    "assets:retry": "node --use-system-ca scripts/asset-manager.mjs retry-failed",
    "assets:report": "node scripts/asset-manager.mjs report",
    "assets:wikimedia": "node --use-system-ca scripts/asset-manager.mjs wikimedia-import"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "sharp": "^0.33.5"
  }
}

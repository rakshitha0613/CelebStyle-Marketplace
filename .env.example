# Root-level environment reference. Copy relevant sections to apps/backend/.env and apps/frontend/.env.local

# Backend — database (SQLite for dev, PostgreSQL for production)
DATABASE_URL="file:./prisma/dev.db"
# DATABASE_URL="postgresql://<user>:<password>@<host>:5432/celebstyle"

# Backend — auth (set a long random string in production)
JWT_SECRET="<replace-with-a-long-random-secret>"

# Backend — optional integrations (not used in current build)
ELASTICSEARCH_URL="http://localhost:9200"

# Frontend — API base URL
NEXT_PUBLIC_API_BASE_URL="http://localhost:4000"
